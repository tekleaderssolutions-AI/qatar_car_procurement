# PostgreSQL connection URL (optional).
# If set, ETL and API use PostgreSQL; if unset, SQLite (qauto.db) is used.
# DATABASE_URL=postgresql://user:password@localhost:5432/qauto

# Example with explicit host/port:
# DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5432/qauto

# Alternative (instead of DATABASE_URL) using discrete env vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=qauto
# DB_USER=postgres
# DB_PASSWORD=secret
# Optional:
# DB_SSLMODE=disable
